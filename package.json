{
  "name": "kiddiespeech",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @kiddiespeech/web",
    "build:web": "npm run build --workspace @kiddiespeech/web",
    "lint:web": "npm run lint --workspace @kiddiespeech/web",
    "dev:mobile": "npm run start --workspace @kiddiespeech/mobile",
    "dev:api": "npm run dev --workspace @kiddiespeech/api",
    "check:api": "npm run check --workspace @kiddiespeech/api"
  }
}
